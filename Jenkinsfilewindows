// Jenkinsfile

// Helper to run the same command on Windows or Linux
def runCmd(cmd) {
    if (isUnix()) {
        sh(script: cmd)
    } else {
        bat(script: cmd)
    }
}

pipeline {
    agent any

    environment {
        // If PATH works: keep as 'trivy'
        // If not, put full path, e.g. 'C:\\Program Files\\Trivy\\trivy.exe'
        TRIVY_EXE = 'trivy'
        IMAGE_NAME = 'demo_app_try'
        IMAGE_TAG  = 'latest'
    }

    stages {

        stage('Build Docker Image') {
            steps {
                script {
                    runCmd """
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                script {
                    if (isUnix()) {
                        // Linux/macOS version
                        sh """
                        rm -rf reports
                        mkdir -p reports

                        curl -L https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -o reports/html.tpl

                        echo "Running Trivy JSON scan..."
                        ${TRIVY_EXE} image --format json -o reports/trivy_report.json --severity MEDIUM,HIGH,CRITICAL ${IMAGE_NAME}:${IMAGE_TAG} || echo "Trivy JSON scan failed (continuing pipeline)"

                        echo "Running Trivy HTML scan..."
                        ${TRIVY_EXE} image --format template --template "@reports/html.tpl" -o reports/trivy_report.html --severity MEDIUM,HIGH,CRITICAL ${IMAGE_NAME}:${IMAGE_TAG} || echo "Trivy HTML scan failed (continuing pipeline)"
                        """
                    } else {
                        // Windows version
                        bat """
                        IF EXIST reports ( rmdir /s /q reports )
                        mkdir reports

                        curl -L https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl -o reports\\html.tpl

                        echo Running Trivy JSON scan...
                        "C:\Trivy\trivy.exe" image --format json -o reports\\trivy_report.json --severity MEDIUM,HIGH,CRITICAL ${IMAGE_NAME}:${IMAGE_TAG}  ||  echo "Trivy JSON scan failed (continuing pipeline)"

                        echo Running Trivy HTML scan...
                        "C:\Trivy\trivy.exe" image --format template --template "@reports\\html.tpl" -o reports\\trivy_report.html --severity MEDIUM,HIGH,CRITICAL ${IMAGE_NAME}:${IMAGE_TAG}  ||  echo "Trivy HTML scan failed (continuing pipeline)"
                        """
                    }
                }
            }
        }

        stage('ZAP Scan (optional)') {
            when {
                expression { return false } // change to true if you want to enable later
            }
            steps {
                script {
                    runCmd """
                    echo Run OWASP ZAP here if needed...
                    """
                }
            }
        }

        stage('Cleanup Docker (optional)') {
            steps {
                script {
                    runCmd """
                    docker image prune -f
                    """
                }
            }
        }
    }

    post {
        always {
            // archive reports if they exist
            script {
                try {
                    archiveArtifacts artifacts: 'reports/*', allowEmptyArchive: true
                } catch (ignored) {
                    echo "No reports to archive."
                }
            }
            cleanWs()
        }
    }
}
